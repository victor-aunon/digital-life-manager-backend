DATABASE_URL=postgresql://user:password@vps-tailscale-ip:5432/dbname
ENCRYPTION_KEY=your-base64-encoded-fernet-key-here
STAGING_DIR=/absolute/path/to/staging
O2_SYNC_DIR=/absolute/path/to/O2/Cloud
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-r2-bucket-name
LOCAL_LLM_URL=http://localhost:11434/api/embeddings
SIGNAL_ATTACHMENTS_DIR=/absolute/path/to/signal-cli/attachments
MAX_HOT_SIZE_MB=50

